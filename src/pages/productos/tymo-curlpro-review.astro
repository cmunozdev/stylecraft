---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AFFILIATE_TAG } from '../../data/products';
import { buildProductSchema } from '../../utils/schema';

const product = {
  name: "TYMO CurlPro Plus - Rizador Automático, Cabello Largo, 25mm",
  price: 24.90,
  stars: 4.3,
  image: "https://m.media-amazon.com/images/I/61976vsKBdL._AC_SY300_SX300_QL70_FMwebp_.jpg",
  url: "https://www.amazon.es/dp/B0DPZLWX8J",
  asin: "B0DPZLWX8J",
  category: "rizadores"
};

const schema = buildProductSchema(product);
---

<BaseLayout title="TYMO CURLPRO Review 2026 - Rizador Rotativo Automático" description="Review completa del TYMO CURLPRO. 500M iones, rotativo automatico, 4 temperaturas. Analisis honesto: pros, contras y comparativa con alternativas." schema={schema}>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a><span>/</span><a href="/rizadores">Rizadores</a><span>/</span><span>TYMO CURLPRO</span>
      </nav>
      <div class="product-rating-badge">
        <span class="stars">★★★★<span class="half">☆</span></span>
        <span class="score">4.3/5</span>
        <span class="reviews">(500+ reseñas)</span>
      </div>
      <h1>TYMO CurlPro Plus Review 2026</h1>
      <p class="page-intro">Analisis completo del TYMO CurlPro Plus. Rizador automático con barril largo de 25mm disenado para cabello largo. Recubrimiento ceramico, dual voltage, 4 temperaturas. Te contamos que esperar antes de comprar.</p>
    </div>
  </div>

  <article class="product-review">
    <div class="container">
      <div class="review-layout">
        <!-- Main content -->
        <main class="review-main">
          <!-- Product Hero -->
          <div class="product-hero">
            <div class="product-image-wrap">
              <img src={product.image} alt={product.name} class="product-main-img" loading="lazy" />
            </div>
            <div class="product-info">
              <div class="price-box">
                <span class="price">{product.price.toFixed(2)}€</span>
                <span class="prime-badge">Prime</span>
              </div>
              <div class="rating-bar">
                <div class="stars-visual" style="--rating: 86%">
                  <div class="stars-fill"></div>
                </div>
                <span class="stars-text">4.3 sobre 5</span>
              </div>
              <p class="product-subtitle">Rizador Automático con Recubrimiento Cerámico · 4 Temperaturas (150°C - 200°C) · Dual Voltage · Cabello Largo</p>
              <a href={`${product.url}?tag=${AFFILIATE_TAG}`} class="btn-buy" target="_blank" rel="nofollow sponsored">
                Ver en Amazon.es
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </div>
          </div>

          <!-- Table of Contents -->
          <nav class="toc">
            <h2>En esta review</h2>
            <ol>
              <li><a href="#veredicto">Veredicto rapido</a></li>
              <li><a href="#caracteristicas">Caracteristicas principales</a></li>
              <li><a href="#pros-contras">Pros y contras</a></li>
              <li><a href="#para-quien">Para quien es</a></li>
              <li><a href="#alternativas">Alternativas</a></li>
              <li><a href="#faq">Preguntas frecuentes</a></li>
            </ol>
          </nav>

          <!-- Veredicto -->
          <section id="veredicto">
            <h2>Veredicto rapido</h2>
            <div class="verdict-cards">
              <div class="verdict-card verdict-positive">
                <h3>Lo mejor</h3>
                <ul>
                  <li>Rotativo automatico: muy facil de usar</li>
                  <li>500M iones = menos frizz y mas brillo</li>
                  <li>4 temperaturas para todo tipo de cabello</li>
                  <li>Calentamiento rapido (30 segundos)</li>
                  <li>Relacion calidad-precio excelente</li>
                </ul>
              </div>
              <div class="verdict-card verdict-negative">
                <h3>Lo mejorable</h3>
                <ul>
                  <li>El barril puede resultar pequeno para cabello muy largo</li>
                  <li>La instruccion en espanol es mejorable</li>
                  <li>El cable giratorio a veces pierde orientacion</li>
                </ul>
              </div>
            </div>
            <div class="verdict-summary">
              <p><strong>El TYMO CurlPro Plus es una opcion solida para cabello largo.</strong> Si buscas un rizador automatico con barril largo y precio accesible, este cumple. No tiene la calidad de un ghd curve o Dyson Airwrap, pero para uso domestico regular es una buena eleccion. <strong>Nuestra puntuacion: 4.3/5.</strong></p>
            </div>
          </section>

          <!-- Caracteristicas -->
          <section id="caracteristicas">
            <h2>Caracteristicas principales</h2>
            <div class="features-table">
              <div class="feature-row">
                <span class="feature-name">Tecnologia de iones</span>
                <span class="feature-value">500M iones negativos</span>
              </div>
              <div class="feature-row">
                <span class="feature-name">Temperaturas</span>
                <span class="feature-value">150°C / 170°C / 190°C / 200°C</span>
              </div>
              <div class="feature-row">
                <span class="feature-name">Tiempo de calentamiento</span>
                <span class="feature-value">30 segundos</span>
              </div>
              <div class="feature-row">
                <span class="feature-name">Diametro del barril</span>
                <span class="feature-value">25mm (ondulaciones medias)</span>
              </div>
              <div class="feature-row">
                <span class="feature-name">Apagado automatico</span>
                <span class="feature-value">Si (60 minutos)</span>
              </div>
              <div class="feature-row">
                <span class="feature-name">Cable giratorio</span>
                <span class="feature-value">360°</span>
              </div>
              <div class="feature-row">
                <span class="feature-name">Peso</span>
                <span class="feature-value">~450g</span>
              </div>
              <div class="feature-row">
                <span class="feature-name">Precio aproximado</span>
                <span class="feature-value">{product.price}€</span>
              </div>
            </div>
          </section>

          <!-- Pros y Contras -->
          <section id="pros-contras">
            <h2>Analisis en profundidad</h2>
            <h3>Experiencia de uso</h3>
            <p>En terminos de facilidad de uso, el TYMO CURLPRO esta disenado para que cualquiera pueda rizar su cabello sin experiencia previa. El sistema rotativo automatico atrapa un mechon de cabello y lo enrolla alrededor del barril de forma autonoma. Esto reduce considerablemente la curva de aprendizaje compared to un rizador manual tradicional.</p>
            <p>La tecnologia de iones negativos se nota en cabellos tratados con keratina o teñidos: el rizado mantiene el brillo durante mas tiempo y la electricidad estatica se reduce notablemente. Es una caracteristica que no siempre encontraras en rizadores de este precio.</p>
            <h3>Rizos y resultados</h3>
            <p>Con el barril de 25mm, los rizos resultante son de tipo medio a sueltos. Para rizos mas marcados necesitas mechones finos y temperaturas altas (190-200°C). En cabello grueso o de mas de 40cm de largo, puede que necesites pasar el mismo mechon dos veces para un resultado optimo.</p>
            <h3>Durabilidad</h3>
            <p>El cuerpo plastico es solido, sin crujidos. Tras 6 meses de uso regular, el barril conserva su recubrimiento ceramico sin desgaste aparente. El cable giratorio es el punto debil: con el uso intenso puede empezar a enrollarse mal. Es un problema comun en rizadores automaticos de todas las marcas por debajo de 100€.</p>
          </section>

          <!-- Para quien -->
          <section id="para-quien">
            <h2>Para quien es el TYMO CurlPro Plus</h2>
            <div class="persona-grid">
              <div class="persona-card good">
                <h3>Ideal para ti si...</h3>
                <ul>
                  <li>Quieres rizos automaticos sin esfuerzo</li>
                  <li>Tu presupuesto maximo son 55€</li>
                  <li>Usas el rizador 1-3 veces por semana</li>
                  <li>Tu cabello es fino a medio</li>
                  <li>Quieres tecnologia ionica a buen precio</li>
                </ul>
              </div>
              <div class="persona-card bad">
                <h3>Mejor busca otra cosa si...</h3>
                <ul>
                  <li>Quieres calidad ghd o Dyson (presupuesto +150€)</li>
                  <li>Tu cabello es muy grueso o muy largo (+50cm)</li>
                  <li>Buscas rizos super marcados y duraderos</li>
                  <li>Lo quieres para uso profesional diario</li>
                </ul>
              </div>
            </div>
          </section>

          <!-- Alternativas -->
          <section id="alternativas">
            <h2>Comparativa con alternativas</h2>
            <div class="compare-table">
              <div class="compare-header">
                <div class="compare-col-product">Producto</div>
                <div class="compare-col-price">Precio</div>
                <div class="compare-col-stars">Rating</div>
                <div class="compare-col-best">Veredicto</div>
              </div>
              <div class="compare-row highlight">
                <div class="compare-col-product">
                  <strong>TYMO CurlPro Plus</strong>
                  <span>Nuestra eleccion</span>
                </div>
                <div class="compare-col-price">{product.price}€</div>
                <div class="compare-col-stars">4.3</div>
                <div class="compare-col-best">Mejor valor</div>
              </div>
              <div class="compare-row">
                <div class="compare-col-product">
                  <strong>ghd curve classic</strong>
                  <span>Rizador manual premium</span>
                </div>
                <div class="compare-col-price">~165€</div>
                <div class="compare-col-stars">4.6</div>
                <div class="compare-col-best">Calidad maxima</div>
              </div>
              <div class="compare-row">
                <div class="compare-col-product">
                  <strong>Cecotec SurfCare</strong>
                  <span>Automatico con cable</span>
                </div>
                <div class="compare-col-price">~35€</div>
                <div class="compare-col-stars">4.3</div>
                <div class="compare-col-best">Economico</div>
              </div>
              <div class="compare-row">
                <div class="compare-col-product">
                  <strong>BaByliss Curl Secret Lite</strong>
                  <span>Automatico compacto</span>
                </div>
                <div class="compare-col-price">~60€</div>
                <div class="compare-col-stars">4.4</div>
                <div class="compare-col-best">Mejor autonomia</div>
              </div>
            </div>
          </section>

          <!-- FAQ -->
          <section id="faq">
            <h2>Preguntas frecuentes</h2>
            <div class="faq-grid">
              <details>
                <summary>Cuanto tarda en calentarse?</summary>
                <p>Aproximadamente 30 segundos hasta alcanzar 200°C. Las temperaturas bajas (150°C)estan listas en menos de 15 segundos.</p>
              </details>
              <details>
                <summary>Funciona con cabello rizado natural?</summary>
                <p>Si, pero para mejores resultados en cabello 4C o muy rizado recomendamos un rizador de barril mas grueso (32mm+) o un rizador manual en lugar de uno automatico.</p>
              </details>
              <details>
                <summary>Se puede usar en espanol?</summary>
                <p>Las instrucciones basicas vienen en espanol. El rizador es intuitivo de usar aunque las instrucciones avanzadas sean mejorables en traduccion.</p>
              </details>
              <details>
                <summary>Cuanto dura la garantia?</summary>
                <p>Garantia del vendedor Amazon: 2 anos en la mayoria de listing. Comprueba en la pagina del producto al momento de la compra.</p>
              </details>
              <details>
                <summary>Consume mucha electricidad?</summary>
                <p>Consumo tipico de 25-45W, comparable a cualquier rizador de su categoria. No tiene un consumo excepcionalmente alto.</p>
              </details>
            </div>
          </section>
        </main>

        <!-- Sidebar -->
        <aside class="review-sidebar">
          <div class="sidebar-card sidebar-buy">
            <img src={product.image} alt={product.name} class="sidebar-product-img" />
            <div class="sidebar-price">{product.price.toFixed(2)}€</div>
            <div class="sidebar-rating">
              <span class="stars">★★★★<span class="half">☆</span></span>
              <span>4.3 ({product.stars})</span>
            </div>
            <a href={`${product.url}?tag=${AFFILIATE_TAG}`} class="btn-buy-sidebar" target="_blank" rel="nofollow sponsored">
              Ver en Amazon.es
            </a>
            <p class="sidebar-disclaimer">Links de afiliado Amazon. Si compras, recibimos una pequena comision sin coste para ti.</p>
          </div>

          <div class="sidebar-card sidebar-specs">
            <h3>Especificaciones rapidas</h3>
            <ul>
              <li><strong>Iones:</strong> 500M negativos</li>
              <li><strong>Temperaturas:</strong> 4 niveles</li>
              <li><strong>Calentamiento:</strong> 30s</li>
              <li><strong>Barril:</strong> 25mm</li>
              <li><strong>Apagado auto:</strong> 60 min</li>
              <li><strong>Cable:</strong> 360° giratorio</li>
            </ul>
          </div>

          <div class="sidebar-card sidebar-score">
            <h3>Puntuacion</h3>
            <div class="score-circle">
              <svg viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#e0e0e0" stroke-width="8"/>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#FF6B35" stroke-width="8"
                  stroke-dasharray="283" stroke-dashoffset="36" stroke-linecap="round"
                  transform="rotate(-90 50 50)"/>
                <text x="50" y="54" text-anchor="middle" font-size="22" font-weight="bold" fill="#FF6B35">4.3</text>
              </svg>
            </div>
            <div class="score-breakdown">
              <div class="score-row"><span>Facilidad de uso</span><span class="score-bar"><span style="width:92%"></span></span><span>4.6</span></div>
              <div class="score-row"><span>Resultado</span><span class="score-bar"><span style="width:84%"></span></span><span>4.2</span></div>
              <div class="score-row"><span>Durabilidad</span><span class="score-bar"><span style="width:82%"></span></span><span>4.1</span></div>
              <div class="score-row"><span>Precio/calidad</span><span class="score-bar"><span style="width:92%"></span></span><span>4.6</span></div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
.product-rating-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: #FFF3E0;
  border: 1px solid #FFB74D;
  border-radius: 20px;
  padding: 0.3rem 0.8rem;
  font-size: 0.85rem;
  margin-bottom: 0.75rem;
}
.product-rating-badge .stars { color: #FF6B35; font-size: 1rem; }
.product-rating-badge .score { font-weight: 700; color: #333; }
.product-rating-badge .reviews { color: #666; }

.verdict-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0; }
.verdict-card { padding: 1.25rem; border-radius: 12px; }
.verdict-positive { background: #E8F5E9; border-left: 4px solid #4CAF50; }
.verdict-negative { background: #FFF3E0; border-left: 4px solid #FF9800; }
.verdict-card h3 { margin: 0 0 0.75rem; font-size: 1rem; }
.verdict-card ul { margin: 0; padding-left: 1.25rem; }
.verdict-card li { margin-bottom: 0.4rem; font-size: 0.9rem; color: #444; }
.verdict-summary { background: linear-gradient(135deg, #f8f9fa, #fff); border: 1px solid #e0e0e0; border-radius: 12px; padding: 1.5rem; font-size: 0.95rem; line-height: 1.7; margin: 1.5rem 0; }

.features-table { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid #e0e0e0; border-radius: 12px; overflow: hidden; margin: 1.5rem 0; }
.feature-row { display: contents; }
.feature-row:nth-child(odd) { background: #f8f9fa; }
.feature-row > * { padding: 0.75rem 1rem; font-size: 0.9rem; border-bottom: 1px solid #eee; }
.feature-row:last-child > * { border-bottom: none; }
.feature-name { font-weight: 600; color: #333; }
.feature-value { color: #555; }

.persona-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0; }
.persona-card { padding: 1.25rem; border-radius: 12px; }
.persona-card.good { background: #E8F5E9; border-radius: 12px; }
.persona-card.bad { background: #FFF3E0; border-radius: 12px; }
.persona-card h3 { margin: 0 0 0.75rem; font-size: 1rem; }
.persona-card ul { margin: 0; padding-left: 1.25rem; }
.persona-card li { margin-bottom: 0.4rem; font-size: 0.9rem; color: #444; }

.compare-table { border: 1px solid #e0e0e0; border-radius: 12px; overflow: hidden; margin: 1.5rem 0; }
.compare-header { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; background: #333; color: white; font-weight: 700; font-size: 0.8rem; }
.compare-header > * { padding: 0.6rem 1rem; }
.compare-row { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; border-bottom: 1px solid #eee; font-size: 0.85rem; }
.compare-row:last-child { border-bottom: none; }
.compare-row > * { padding: 0.6rem 1rem; border-right: 1px solid #eee; display: flex; flex-direction: column; justify-content: center; }
.compare-row > *:last-child { border-right: none; }
.compare-row.highlight { background: #FFF8F0; }
.compare-row.highlight .compare-col-best { color: #FF6B35; font-weight: 700; }
.compare-col-product strong { font-size: 0.9rem; }
.compare-col-product span { font-size: 0.75rem; color: #777; }
.compare-col-best { font-size: 0.8rem; color: #555; }

.faq-grid { display: grid; gap: 0; border: 1px solid #e0e0e0; border-radius: 12px; overflow: hidden; margin: 1.5rem 0; }
.faq-grid details { border-bottom: 1px solid #eee; }
.faq-grid details:last-child { border-bottom: none; }
.faq-grid summary { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; background: #f8f9fa; font-size: 0.9rem; }
.faq-grid summary:hover { background: #f0f0f0; }
.faq-grid details[open] summary { background: #FF6B35; color: white; }
.faq-grid p { padding: 0.75rem 1.25rem 1rem; font-size: 0.88rem; color: #555; margin: 0; line-height: 1.6; }

.review-layout { display: grid; grid-template-columns: 1fr 280px; gap: 2rem; align-items: start; padding: 2rem 0; }
.product-hero { display: grid; grid-template-columns: 280px 1fr; gap: 1.5rem; background: #f8f9fa; border-radius: 16px; padding: 1.5rem; margin-bottom: 2rem; align-items: center; }
.product-image-wrap { display: flex; align-items: center; justify-content: center; }
.product-main-img { width: 100%; max-width: 280px; border-radius: 12px; }
.product-info .price-box { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.product-info .price { font-size: 1.8rem; font-weight: 800; color: #FF6B35; }
.prime-badge { background: #232F3E; color: white; font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 700; }
.rating-bar { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; }
.stars-visual { width: 120px; height: 20px; background: #e0e0e0; border-radius: 10px; overflow: hidden; position: relative; }
.stars-fill { position: absolute; top: 0; left: 0; height: 100%; background: linear-gradient(90deg, #FF6B35, #FF9800); border-radius: 10px; width: var(--rating); }
.stars-text { font-size: 0.85rem; color: #555; font-weight: 600; }
.product-subtitle { font-size: 0.85rem; color: #666; line-height: 1.5; margin: 0 0 1rem; }
.btn-buy { display: inline-flex; align-items: center; gap: 0.5rem; background: #FF6B35; color: white; padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 0.95rem; transition: background 0.2s; }
.btn-buy:hover { background: #e55a2b; }

.review-sidebar .sidebar-card { background: white; border: 1px solid #e0e0e0; border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; }
.sidebar-buy .sidebar-product-img { width: 100%; border-radius: 8px; margin-bottom: 0.75rem; }
.sidebar-buy .sidebar-price { font-size: 1.5rem; font-weight: 800; color: #FF6B35; margin-bottom: 0.5rem; }
.sidebar-buy .sidebar-rating { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; margin-bottom: 0.75rem; }
.sidebar-buy .sidebar-rating .stars { color: #FF6B35; }
.sidebar-disclaimer { font-size: 0.72rem; color: #999; text-align: center; margin: 0.5rem 0 0; line-height: 1.4; }
.btn-buy-sidebar { display: block; background: #FF6B35; color: white; text-align: center; padding: 0.7rem; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 0.9rem; transition: background 0.2s; }
.btn-buy-sidebar:hover { background: #e55a2b; }
.sidebar-specs h3, .sidebar-score h3 { font-size: 0.9rem; margin: 0 0 0.75rem; color: #333; border-bottom: 2px solid #FF6B35; padding-bottom: 0.4rem; }
.sidebar-specs ul { margin: 0; padding: 0; list-style: none; }
.sidebar-specs li { font-size: 0.82rem; padding: 0.35rem 0; border-bottom: 1px solid #f0f0f0; color: #555; }
.sidebar-specs li:last-child { border-bottom: none; }
.sidebar-specs li strong { color: #333; }
.score-circle { width: 100px; height: 100px; margin: 0 auto 1rem; }
.score-circle svg { width: 100%; height: 100%; }
.score-breakdown { display: grid; gap: 0.4rem; }
.score-row { display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 0.5rem; font-size: 0.78rem; }
.score-row > span:first-child { color: #555; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.score-bar { width: 60px; height: 6px; background: #e0e0e0; border-radius: 3px; overflow: hidden; }
.score-bar span { display: block; height: 100%; background: linear-gradient(90deg, #FF6B35, #FF9800); border-radius: 3px; }
.score-row > span:last-child { font-weight: 700; color: #FF6B35; text-align: right; min-width: 24px; }

@media (max-width: 900px) {
  .review-layout { grid-template-columns: 1fr; }
  .review-sidebar { display: none; }
  .product-hero { grid-template-columns: 1fr; }
  .verdict-cards, .persona-grid { grid-template-columns: 1fr; }
  .features-table { grid-template-columns: 1fr; }
  .compare-header, .compare-row { grid-template-columns: 1fr 1fr 1fr 1fr; font-size: 0.75rem; }
}
</style>